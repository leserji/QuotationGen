generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Quotation {
  id         Int       @id @default(autoincrement())
  number     String    @unique
  date       DateTime
  clientName String
  currency   String
  notes      String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  sections   Section[]
  items      LineItem[]
}

model Section {
  id          Int       @id @default(autoincrement())
  quotationId Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name        String
  order       Int
  items       LineItem[]
}

model LineItem {
  id          Int      @id @default(autoincrement())
  quotationId Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  sectionId   Int?
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  itemNumber  String
  service     String
  description String
  price       Float
  order       Int
}
